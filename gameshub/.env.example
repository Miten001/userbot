# ===== Site =====
NEXT_PUBLIC_SITE_NAME="PlayHub"
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# ===== Gamemonetize =====
# Auto-fetches 1000 games from this feed every 24h.
# Default works out of the box. To customize (different category, amount,
# RSS instead of JSON), generate a new URL at:
#   https://gamemonetize.com/rss-builder
GAMEMONETIZE_FEED_URL="https://gamemonetize.com/rss-feed.php?format=0&amount=1000&category=All&type=html5&company=All&gateway=All"

# Optional: your Gamemonetize publisher ID for revenue tracking.
# Find it under your account on https://gamemonetize.com after registering
# your site. Once set, every game iframe URL will include the tracking param.
NEXT_PUBLIC_GAMEMONETIZE_PUBLISHER=""

# ===== Google AdSense =====
# Sign up at https://adsense.google.com — get approved, then paste your client ID below.
# Format: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=""

# Per-slot ad unit IDs (create them inside AdSense > Ads > By ad unit)
NEXT_PUBLIC_AD_SLOT_HEADER=""
NEXT_PUBLIC_AD_SLOT_SIDEBAR=""
NEXT_PUBLIC_AD_SLOT_INCONTENT=""
NEXT_PUBLIC_AD_SLOT_FOOTER=""

# ===== Optional: Google Analytics =====
NEXT_PUBLIC_GA_ID=""
