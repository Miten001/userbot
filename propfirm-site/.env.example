# ApexFunded backend env vars
# Copy to .env.local for dev, or add in Vercel project settings for production.

# === Public site URL (used for Stripe redirects) ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Supabase (https://supabase.com -> create project -> Settings -> API) ===
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Stripe (https://dashboard.stripe.com -> Developers -> API keys) ===
# Test mode keys for now. Switch to live keys when ready.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# === MT5 / MetaApi (https://metaapi.cloud) ===
# Leave empty to use the built-in MOCK provider (fake account numbers).
# When you sign up at metaapi.cloud, paste your API token here.
METAAPI_TOKEN=
METAAPI_REGION=new-york

# Optional: comma-separated list of admin user IDs (Supabase user.id) who can see /admin
ADMIN_USER_IDS=
